@{
    ViewData["Title"] = "Home Page";
}

<div class="container-fluid p-0">
    <video autoplay
           muted
           loop
           playsinline
           style="width:100%;height:100vh;object-fit:cover;display:block;">
        <source src="@Url.Content("~/video/onevideo.mp4")" type="video/mp4">
        Your browser does not support the video tag.
    </video>
</div>

<div class="container my-5">
    <h1 class="text-danger">Hello</h1>

    <div class="card" style="width:18rem;">
        <img src="~/Images/img1.png" class="card-img-top" alt="Test">
        <div class="card-body">
            <h5 class="card-title">Test Card</h5>
            <p>This is a test.</p>
        </div>
    </div>
</div>



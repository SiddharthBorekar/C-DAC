<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - One8</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/One8.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container-fluid">

                <!-- Left Menu -->
                <div class="d-flex">
                    <ul class="navbar-nav flex-row">
                        <li class="nav-item me-3">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Featured</a>
                        </li>
                        <li class="nav-item me-3">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">Women</a>
                        </li>
                        <li class="nav-item me-3">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">Men</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">Release Calendar</a>
                        </li>
                    </ul>
                </div>

                <!-- Center Brand -->
                <a class="navbar-brand d-flex align-items-center"
                   asp-area=""
                   asp-controller="Home"
                   asp-action="Index">
                    <img src="~/Image/logo.png"
                         alt="One8 Logo"
                         class="img-fluid"
                         style="height:60px;">
                </a>

                <!-- Right Search -->
                <form class="d-flex">
                    <input class="form-control me-2 rounded-pill"
                           type="search"
                           placeholder="Search"
                           aria-label="Search">
                    <button class="btn btn-dark rounded-pill px-4" type="submit">
                        Search
                    </button>
                </form>

            </div>
        </nav>
    </header>


    <div class="container-fluid p-0 flex-grow-1">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-light" style="background-color:#1A1A1A;">
        <div class="container-fluid p-0">
            <div class="row mx-0 align-items-center" style="min-height: 300px;">
                <div class="col text-center py-3">
                    <img src="~/Image/one8-logo-transparent.png"
                         alt="One8 Logo"
                         class="img-fluid"
                         style="max-width:60%; height:auto;">
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>